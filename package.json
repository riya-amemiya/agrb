{
	"name": "agrb",
	"version": "1.5.0",
	"description": "Interactive CLI to rebase a branch onto another safely (cherry-pick or linear rebase)",
	"license": "MIT",
	"bin": "dist/cli.js",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/riya-amemiya/agrb.git"
	},
	"homepage": "https://github.com/riya-amemiya/agrb#readme",
	"bugs": {
		"url": "https://github.com/riya-amemiya/agrb/issues"
	},
	"scripts": {
		"build": "tsc --noEmit && vite build",
		"dev": "vite build --watch",
		"test": "biome check .",
		"eslint": "eslint src",
		"lint": "biome check . --write",
		"ci": "biome ci .",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist"
	],
	"keywords": [
		"git",
		"rebase",
		"cherry-pick",
		"cli",
		"ink",
		"github"
	],
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"ag-toolkit": "0.5.0",
		"ink": "7.0.1",
		"ink-select-input": "6.2.0",
		"ink-spinner": "5.0.0",
		"react": "19.2.5",
		"simple-git": "3.36.0",
		"umt": "2.16.0"
	},
	"overrides": {
		"react": "19.2.5",
		"ink": "7.0.1",
		"ink-select-input": "6.2.0",
		"ink-spinner": "5.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@eslint/js": "^10.0.1",
		"@sindresorhus/tsconfig": "8.1.0",
		"@types/bun": "1.3.13",
		"@types/react": "19.2.14",
		"@typescript-eslint/eslint-plugin": "8.59.1",
		"@typescript-eslint/parser": "8.59.1",
		"chalk": "5.6.2",
		"eslint": "10.2.1",
		"eslint-plugin-unicorn": "64.0.0",
		"ink-testing-library": "4.0.0",
		"ts-node": "10.9.2",
		"typescript": "6.0.3",
		"vite": "8.0.9"
	}
}
